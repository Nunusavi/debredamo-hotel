// DEBREDAMO HOTEL - Prisma Schema
// PostgreSQL database with Neon

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// ROOMS
// =============================================
model Room {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  nameAm        String?  @map("name_am")
  description   String?
  descriptionAm String?  @map("description_am")
  roomType      RoomType @map("room_type")
  sizeM2        Int?     @map("size_sqm")
  maxGuests     Int      @map("max_guests")
  basePriceEtb  Decimal  @map("base_price_etb") @db.Decimal(10, 2)

  // JSONB fields for complex data
  images        Json     @default("[]")
  amenities     Json     @default("[]")

  isActive      Boolean  @default(true) @map("is_active")
  displayOrder  Int      @default(0) @map("display_order")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([isActive])
  @@index([roomType])
  @@index([displayOrder])
  @@map("rooms")
}

enum RoomType {
  standard
  deluxe
  executive
  presidential
}

// =============================================
// PAGES (CMS)
// =============================================
model Page {
  id              String   @id @default(uuid())
  slug            String   @unique
  title           String
  titleAm         String?  @map("title_am")
  content         Json?
  heroImage       String?  @map("hero_image")
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  ogImage         String?  @map("og_image")
  isPublished     Boolean  @default(false) @map("is_published")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([isPublished])
  @@map("pages")
}

// =============================================
// BLOG POSTS
// =============================================
model BlogPost {
  id              String    @id @default(uuid())
  slug            String    @unique
  title           String
  titleAm         String?   @map("title_am")
  excerpt         String?
  content         String?
  featuredImage   String?   @map("featured_image")
  author          String?
  category        String?
  tags            Json      @default("[]")
  metaTitle       String?   @map("meta_title")
  metaDescription String?   @map("meta_description")
  isPublished     Boolean   @default(false) @map("is_published")
  publishedAt     DateTime? @map("published_at")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([isPublished, publishedAt(sort: Desc)])
  @@index([category])
  @@index([slug])
  @@map("blog_posts")
}

// =============================================
// SITE SETTINGS
// =============================================
model SiteSetting {
  key         String   @id
  value       Json
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// =============================================
// CONTACT SUBMISSIONS
// =============================================
model ContactSubmission {
  id        String        @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    ContactStatus @default(new)

  createdAt DateTime      @default(now()) @map("created_at")

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("contact_submissions")
}

enum ContactStatus {
  new
  read
  replied
}
